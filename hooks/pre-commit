#!/usr/bin/env bash
# pre-commit: lint → test → build 순서로 실행. 하나라도 실패하면 커밋 차단.
# 설치: bash hooks/install-hooks.sh

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

pass() { echo -e "${GREEN}✔${NC} $1"; }
fail() { echo -e "${RED}✖${NC} $1"; }
info() { echo -e "${CYAN}▶${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}  pre-commit: Lint → Test → Build${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

FAILED=0

# ── 스택 감지 ─────────────────────────────────────────────────────────────────

HAS_PYPROJECT=false
HAS_REQUIREMENTS=false
HAS_POM=false
HAS_GRADLE=false
HAS_PACKAGE_JSON=false
HAS_MAKEFILE=false

[ -f "pyproject.toml" ]    && HAS_PYPROJECT=true
[ -f "requirements.txt" ]  && HAS_REQUIREMENTS=true
[ -f "pom.xml" ]           && HAS_POM=true
[ -f "build.gradle" ] || [ -f "build.gradle.kts" ] && HAS_GRADLE=true
[ -f "package.json" ]      && HAS_PACKAGE_JSON=true
[ -f "Makefile" ]          && HAS_MAKEFILE=true

# Makefile에 타겟이 있는지 확인하는 헬퍼
has_make_target() {
  grep -qE "^$1\s*:" Makefile 2>/dev/null
}

# ── Python / FastAPI ──────────────────────────────────────────────────────────

if $HAS_PYPROJECT || $HAS_REQUIREMENTS; then
  echo ""
  info "Python 스택 감지"

  # Lint
  info "Lint (ruff check)"
  if command -v uv &>/dev/null; then
    if uv run ruff check . --quiet 2>&1; then
      pass "ruff check"
    else
      fail "ruff check 실패 — 커밋 차단"
      FAILED=1
    fi

    info "Format (ruff format --check)"
    if uv run ruff format . --check --quiet 2>&1; then
      pass "ruff format"
    else
      fail "ruff format 실패 — 'uv run ruff format .' 실행 후 재커밋"
      FAILED=1
    fi
  elif command -v ruff &>/dev/null; then
    if ruff check . --quiet 2>&1; then
      pass "ruff check"
    else
      fail "ruff check 실패"
      FAILED=1
    fi
  else
    warn "ruff 없음 — Python lint 스킵"
  fi

  # Test
  if [ "$FAILED" -eq 0 ]; then
    info "Test (pytest -x -m 'not slow and not integration')"
    if command -v uv &>/dev/null; then
      if uv run pytest -x -q -m "not slow and not integration" 2>&1; then
        pass "pytest"
      else
        fail "pytest 실패 — 커밋 차단"
        FAILED=1
      fi
    elif command -v pytest &>/dev/null; then
      if pytest -x -q -m "not slow and not integration" 2>&1; then
        pass "pytest"
      else
        fail "pytest 실패"
        FAILED=1
      fi
    else
      warn "pytest 없음 — Python test 스킵"
    fi
  fi

  # Build (pyproject.toml 기준, 빌드 타겟이 있을 때만)
  if [ "$FAILED" -eq 0 ] && command -v uv &>/dev/null; then
    if grep -q '^\[build-system\]' pyproject.toml 2>/dev/null; then
      info "Build (uv build)"
      if uv build --quiet 2>&1; then
        pass "uv build"
        rm -rf dist/
      else
        fail "uv build 실패 — 커밋 차단"
        FAILED=1
      fi
    fi
  fi
fi

# ── Java / Maven ──────────────────────────────────────────────────────────────

if $HAS_POM; then
  echo ""
  info "Maven 스택 감지"

  # Lint (Checkstyle / Spotless)
  info "Lint (mvn validate)"
  if mvn validate -q 2>&1; then
    pass "mvn validate"
  else
    fail "mvn validate 실패 — 커밋 차단"
    FAILED=1
  fi

  # Test
  if [ "$FAILED" -eq 0 ]; then
    info "Test (mvn test -Dgroups=unit)"
    if mvn test -Dgroups="unit" -q 2>&1; then
      pass "mvn test"
    else
      fail "mvn test 실패 — 커밋 차단"
      FAILED=1
    fi
  fi

  # Build
  if [ "$FAILED" -eq 0 ]; then
    info "Build (mvn package -DskipTests)"
    if mvn package -DskipTests -q 2>&1; then
      pass "mvn package"
    else
      fail "mvn package 실패 — 커밋 차단"
      FAILED=1
    fi
  fi
fi

# ── Java / Gradle ─────────────────────────────────────────────────────────────

if $HAS_GRADLE && ! $HAS_POM; then
  echo ""
  info "Gradle 스택 감지"

  # Lint
  info "Lint (./gradlew check -x test)"
  if ./gradlew check -x test -q 2>&1; then
    pass "gradlew check"
  else
    fail "gradlew check 실패 — 커밋 차단"
    FAILED=1
  fi

  # Test
  if [ "$FAILED" -eq 0 ]; then
    info "Test (./gradlew test -PexcludeTags=integration,slow)"
    if ./gradlew test -PexcludeTags="integration,slow" -q 2>&1; then
      pass "gradlew test"
    else
      fail "gradlew test 실패 — 커밋 차단"
      FAILED=1
    fi
  fi

  # Build
  if [ "$FAILED" -eq 0 ]; then
    info "Build (./gradlew assemble)"
    if ./gradlew assemble -q 2>&1; then
      pass "gradlew assemble"
    else
      fail "gradlew assemble 실패 — 커밋 차단"
      FAILED=1
    fi
  fi
fi

# ── Node.js / React ───────────────────────────────────────────────────────────

if $HAS_PACKAGE_JSON; then
  echo ""
  info "Node.js 스택 감지"

  # Lint
  info "Lint (npm run lint)"
  if npm run lint --silent 2>&1; then
    pass "npm lint"
  elif npx eslint . --quiet 2>&1; then
    pass "eslint"
  else
    fail "lint 실패 — 커밋 차단"
    FAILED=1
  fi

  # TypeScript 타입 체크
  if [ "$FAILED" -eq 0 ] && [ -f "tsconfig.json" ]; then
    info "Type check (tsc --noEmit)"
    if npx tsc --noEmit 2>&1; then
      pass "tsc"
    else
      fail "tsc 실패 — 커밋 차단"
      FAILED=1
    fi
  fi

  # Test
  if [ "$FAILED" -eq 0 ]; then
    info "Test (npm test)"
    if npm test -- --watchAll=false --passWithNoTests 2>&1; then
      pass "npm test"
    elif npx vitest run 2>&1; then
      pass "vitest"
    else
      fail "test 실패 — 커밋 차단"
      FAILED=1
    fi
  fi

  # Build
  if [ "$FAILED" -eq 0 ]; then
    info "Build (npm run build)"
    if npm run build --silent 2>&1; then
      pass "npm build"
    else
      fail "build 실패 — 커밋 차단"
      FAILED=1
    fi
  fi
fi

# ── Makefile ──────────────────────────────────────────────────────────────────

if $HAS_MAKEFILE && ! $HAS_PYPROJECT && ! $HAS_POM && ! $HAS_GRADLE && ! $HAS_PACKAGE_JSON; then
  echo ""
  info "Makefile 스택 감지"

  for target in lint test build check; do
    if has_make_target "$target"; then
      info "make $target"
      if make "$target" 2>&1; then
        pass "make $target"
      else
        fail "make $target 실패 — 커밋 차단"
        FAILED=1
        break
      fi
    fi
  done
fi

# ── 스택 미감지 ───────────────────────────────────────────────────────────────

if ! $HAS_PYPROJECT && ! $HAS_REQUIREMENTS && ! $HAS_POM && ! $HAS_GRADLE && ! $HAS_PACKAGE_JSON && ! $HAS_MAKEFILE; then
  warn "알려진 스택 없음 — lint·test·build 스킵"
fi

# ── lint·test·build 결과 ──────────────────────────────────────────────────────

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [ "$FAILED" -ne 0 ]; then
  echo -e "${RED}  커밋 차단: lint·test·build 중 하나 이상 실패${NC}"
  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  exit 1
fi
echo -e "${GREEN}  lint·test·build 통과${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# ── diff 리뷰 (sub-agent) ─────────────────────────────────────────────────────

REVIEW_HOOK="$(dirname "$0")/pre-commit-review"
if [ -x "$REVIEW_HOOK" ]; then
  "$REVIEW_HOOK"
fi
